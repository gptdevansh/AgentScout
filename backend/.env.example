# ── Application ─────────────────────────────────────────────────────
APP_NAME=AgentScout
APP_VERSION=0.1.0
DEBUG=true
LOG_LEVEL=DEBUG

# ── Server ──────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000

# ── Database ────────────────────────────────────────────────────────
POSTGRES_USER=agentscout
POSTGRES_PASSWORD=agentscout
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=agentscout

# ── Azure OpenAI ────────────────────────────────────────────────────
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_KEY=your-api-key
AZURE_OPENAI_API_VERSION=2024-12-01-preview
GPT_MODEL_NAME=gpt-5.1-chat
DEEPSEEK_MODEL_NAME=deepseek-r1

# ── Apify ───────────────────────────────────────────────────────────
APIFY_API_TOKEN=your-apify-token

# ── Tuning ──────────────────────────────────────────────────────────
MAX_SEARCH_QUERIES=30
MAX_POSTS_PER_QUERY=10
DEBATE_ROUNDS=3
